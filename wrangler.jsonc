// Aliveville on Cloudflare: Workers Assets serve the built 3D client,
// one Durable Object per visitor session runs the sim.
// Deploy: pnpm build:3d && npx wrangler deploy
// Secrets: npx wrangler secret put LLM_API_KEY ; npx wrangler secret put ADMIN_TOKEN
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aliveville",
  "main": "worker/src/index.ts",
  "compatibility_date": "2025-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/site",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [{ "name": "SESSIONS", "class_name": "GameSessionDO" }]
  },
  // same-account worker→worker fetches over workers.dev are blocked;
  // the LLM gateway is called through this service binding instead
  "services": [{ "binding": "GATEWAY", "service": "free-ai-gateway" }],
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["GameSessionDO"] }],
  "vars": {
    "LLM_BASE_URL": "https://ai-gateway.sassmaker.com/v1",
    // picked from the gateway's /v1/routing/status healthy set; pinned via
    // x-gateway-force-model header (body.model is advisory at the gateway)
    "LLM_MODEL_NORMAL": "mistral-large",
    "LLM_MODEL_QUEST": "mistral-large",
    "LLM_MODEL_PROPOSE": "cerebras-llama-8b",
    "LLM_MODEL_RESEARCH": "mistral-large",
    "LLM_TIMEOUT_MS": "20000",
    "LLM_PROJECT_ID": "ai-game"
  },
  "workers_dev": true,
  // path route on the existing zone — the landing site keeps the root
  "routes": [{ "pattern": "aliveville.com/game*", "zone_name": "aliveville.com" }],
  "observability": { "enabled": true }
}
