// Aliveville on Cloudflare: Workers Assets serve the built 3D client,
// one Durable Object per visitor session runs the sim.
// Deploy: pnpm build:3d && npx wrangler deploy
// Secrets: npx wrangler secret put LLM_API_KEY ; npx wrangler secret put ADMIN_TOKEN
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aliveville",
  "main": "worker/src/index.ts",
  "compatibility_date": "2025-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/web3d",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [{ "name": "SESSIONS", "class_name": "GameSessionDO" }]
  },
  // same-account worker→worker fetches over workers.dev are blocked;
  // the LLM gateway is called through this service binding instead
  "services": [{ "binding": "GATEWAY", "service": "free-ai-gateway" }],
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["GameSessionDO"] }],
  "vars": {
    "LLM_BASE_URL": "https://free-ai-gateway.sarthakagrawal927.workers.dev/v1",
    // groq-llama-70b 404s upstream (deprecated); the gateway currently
    // resolves these through its fallback chain
    "LLM_MODEL_NORMAL": "groq-gpt-oss-120b",
    "LLM_MODEL_QUEST": "groq-gpt-oss-120b",
    "LLM_PROJECT_ID": "ai-game"
  },
  "workers_dev": true,
  // re-enable once the aliveville.com zone is active in this account:
  // "routes": [
  //   { "pattern": "aliveville.com", "custom_domain": true },
  //   { "pattern": "www.aliveville.com", "custom_domain": true }
  // ],
  "observability": { "enabled": true }
}
