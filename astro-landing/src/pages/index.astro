---
import ThreeBackground from '../components/ThreeBackground.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="bg-[#010102] scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aliveville — A browser-playable AI world simulator</title>
    <meta name="description" content="Aliveville is a browser-playable AI world simulator. Walk a 3D town where autonomous agents live, remember, and react in real time. No install." />
    <meta name="keywords" content="AI world simulator, browser AI game, autonomous NPCs, 3D AI town, playable AI simulation, persistent AI agents" />
    <meta name="author" content="Sarthak Agrawal" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href="https://aliveville.com/" />
    <meta property="og:url" content="https://aliveville.com/" />
    <meta property="og:title" content="Aliveville — A browser-playable AI world simulator" />
    <meta property="og:description" content="Walk a 3D town where autonomous AI agents live, remember, and react in real time. Plays in the browser." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://aliveville.com/assets/ashment_intro_square.jpg" />
    <meta property="og:site_name" content="Aliveville" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Aliveville — A browser-playable AI world simulator" />
    <meta name="twitter:description" content="Walk a 3D town where 5 AI agents live their own day — remembering people, holding grudges, and gossiping while you explore." />
    <meta name="twitter:image" content="https://aliveville.com/assets/ashment_intro_square.jpg" />
    <style>
        :root {
            --accent: #f8d44e;
            --accent-muted: #c2a36b;
            --bg: #010102;
            --surface: #0a0a0c;
            --border: rgba(255, 255, 255, 0.04);
            /* System stack — zero font fetch on LCP path for sub-300ms. */
            --font-main: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            --font-display: ui-serif, 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
        }

        body {
            background-color: var(--bg);
            color: #d1d1d6;
            font-family: var(--font-main);
            margin: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            cursor: none;
        }

        /* --- 99.9999% MAGNETIC CURSOR --- */
        #custom-cursor {
            position: fixed;
            top: 0;
            left: 0;
            width: 8px;
            height: 8px;
            background-color: var(--accent);
            border-radius: 50%;
            pointer-events: none;
            z-index: 10000;
            mix-blend-mode: difference;
            transition: width 0.3s, height 0.3s, background-color 0.3s;
        }

        #cursor-follower {
            position: fixed;
            top: 0;
            left: 0;
            width: 40px;
            height: 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transition: width 0.4s, height 0.4s, border-color 0.4s, background-color 0.4s;
        }

        body.cursor-hover #custom-cursor {
            width: 4px;
            height: 4px;
            background-color: #fff;
        }

        body.cursor-hover #cursor-follower {
            width: 80px;
            height: 80px;
            border-color: var(--accent);
            background-color: rgba(248, 212, 78, 0.05);
        }

        /* --- PROFESSIONAL UI ELEMENTS --- */
        .glass-card {
            background: rgba(10, 10, 12, 0.3);
            backdrop-filter: blur(40px);
            border: 1px solid var(--border);
            border-radius: 4px;
            transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
            position: relative;
            overflow: hidden;
        }

        .glass-card:hover {
            border-color: rgba(248, 212, 78, 0.3);
            background: rgba(15, 15, 18, 0.5);
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: 280px;
            gap: 20px;
        }

        .bento-item { position: relative; overflow: hidden; }
        .col-span-2 { grid-column: span 2; }
        .row-span-2 { grid-row: span 2; }

        .btn-pro {
            position: relative;
            padding: 14px 32px;
            background: #fff;
            color: #000;
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 0.7rem;
            border-radius: 2px;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            border: none;
            overflow: hidden;
            cursor: none;
        }

        .btn-pro::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
            transition: left 0.5s;
        }

        .btn-pro:hover {
            letter-spacing: 0.25em;
            box-shadow: 0 0 40px rgba(255, 255, 255, 0.2);
        }

        .btn-pro:hover::after {
            left: 100%;
        }

        /* --- LARGE PRIMARY PLAY CTA --- */
        .play-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.6em;
            padding: 1.15rem 3.5rem;
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 1.15rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #1a1206;
            background: linear-gradient(180deg, #ffd766, #f5a30b);
            border-radius: 4px;
            box-shadow: 0 0 0 1px rgba(248, 212, 78, 0.5), 0 18px 50px rgba(245, 158, 11, 0.35);
            transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s, letter-spacing 0.25s;
            cursor: none;
        }
        .play-cta:hover {
            transform: translateY(-3px) scale(1.03);
            letter-spacing: 0.24em;
            box-shadow: 0 0 0 1px rgba(248, 212, 78, 0.8), 0 26px 70px rgba(245, 158, 11, 0.55);
        }
        @media (max-width: 640px) {
            .play-cta { padding: 1rem 2.4rem; font-size: 1rem; }
        }

        .tag {
            font-family: var(--font-mono);
            font-size: 0.6rem;
            padding: 5px 12px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 2px;
            color: rgba(255, 255, 255, 0.4);
            text-transform: uppercase;
            letter-spacing: 0.2em;
        }

        /* --- NAVIGATION --- */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            padding: 32px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.5s ease;
        }

        .logo {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 900;
            letter-spacing: 0.4em;
            color: #fff;
        }

        .nav-links a {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: rgba(255, 255, 255, 0.3);
            margin: 0 20px;
            transition: color 0.3s, letter-spacing 0.3s;
            text-decoration: none;
        }

        .nav-links a:hover {
            color: var(--accent);
            letter-spacing: 0.25em;
        }

        /* --- HERO --- */
        .hero-title {
            font-family: var(--font-display);
            font-size: clamp(3rem, 12vw, 12rem);
            line-height: 0.85;
            font-weight: 900;
            letter-spacing: -0.05em;
            text-align: center;
            margin: 0;
        }

        .gradient-text {
            background: linear-gradient(180deg, #fff 40%, rgba(255, 255, 255, 0.1) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* --- ANIMATIONS ---
           LCP-friendly variant: the hero h1 "ASHMENT" is the LCP element.
           Lighthouse won't credit a paint for an element at opacity:0,
           so the original 1s fade-in delayed the LCP by ~1.5s. We keep
           the upward slide so the entrance still feels alive, but the
           text is opaque from frame 1. psi-swarm desktop p75 dropped
           ~4s after this change. */
        @keyframes reveal {
            from { transform: translateY(20px); }
            to { transform: translateY(0); }
        }

        .animate-reveal {
            animation: reveal 1s cubic-bezier(0.2, 1, 0.3, 1) forwards;
        }

        .noise-overlay {
            position: fixed;
            inset: 0;
            z-index: 99999;
            pointer-events: none;
            opacity: 0.06;
            background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');
        }

        .chromatic-layer {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background:
                radial-gradient(circle at 18% 22%, rgba(248, 212, 78, 0.08), transparent 24%),
                radial-gradient(circle at 78% 68%, rgba(86, 166, 255, 0.07), transparent 28%);
            mix-blend-mode: screen;
        }

        .telemetry {
            position: fixed;
            top: 18vh;
            bottom: 18vh;
            z-index: 20;
            width: 22px;
            overflow: hidden;
            pointer-events: none;
            color: rgba(248, 212, 78, 0.28);
            font-family: var(--font-mono);
            font-size: 0.55rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
        }

        .telemetry-left { left: 28px; }
        .telemetry-right { right: 28px; }
        .telemetry-scroll {
            display: flex;
            flex-direction: column;
            gap: 32px;
            writing-mode: vertical-rl;
            animation: telemetry-drift 34s linear infinite;
        }

        @keyframes telemetry-drift {
            from { transform: translateY(0); }
            to { transform: translateY(-50%); }
        }

        @media (max-width: 768px) {
            .telemetry,
            .chromatic-layer {
                display: none;
            }
        }

        /* --- GAME CONTROL CENTER --- */
        .control-center {
            background: #050507;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 40px 120px rgba(0, 0, 0, 0.9);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }

        .control-header {
            padding: 20px 32px;
            background: #0a0a0c;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #4caf50;
            box-shadow: 0 0 12px #4caf50;
        }

        .ticker-line {
            font-family: var(--font-mono);
            font-size: 0.6rem;
            color: #444;
            letter-spacing: 0.05em;
            margin: 0;
        }

        @keyframes ticker {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        .animate-ticker {
            animation: ticker 40s linear infinite;
        }

        @keyframes glitch {
            0% { transform: translate(0); }
            20% { transform: translate(-2px, 2px); }
            40% { transform: translate(-2px, -2px); }
            60% { transform: translate(2px, 2px); }
            80% { transform: translate(2px, -2px); }
            100% { transform: translate(0); }
        }

        .glitch-hover:hover {
            animation: glitch 0.3s infinite;
            color: var(--accent) !important;
        }
    </style>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Aliveville",
      "url": "https://aliveville.com/",
      "description": "A browser-playable AI world simulator. Walk a 3D town where autonomous agents live, remember, and react in real time.",
      "inLanguage": "en"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Aliveville?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Aliveville is a browser-playable AI world simulator where five autonomous AI agents live their own daily lives in a 3D town. They remember people, hold grudges, and gossip while you explore. No install is required — it runs directly in modern web browsers."
          }
        },
        {
          "@type": "Question",
          "name": "Is Aliveville free to play?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Aliveville is free to play. It runs in your browser with no install required. You can walk the 3D town using WASD controls and interact with autonomous AI villagers immediately, with no download, account, or payment needed to start exploring."
          }
        },
        {
          "@type": "Question",
          "name": "Do the AI agents in Aliveville have memory?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, NPCs use location-aware memory retrieval. They only recall what is relevant to their current context, state, and social bonds. Autonomous loops continue even when you are away, so agents keep living, remembering, and evolving their relationships over time."
          }
        },
        {
          "@type": "Question",
          "name": "Can I play Aliveville without downloading anything?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Aliveville is browser-playable with no install. It runs directly in modern browsers with real-time lighting and 3D atmosphere. Open the page, pick a hero, and walk the town using WASD controls — there is nothing to download or set up first."
          }
        },
        {
          "@type": "Question",
          "name": "How does the AI world simulation work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Agents keep their schedules, relationships, memories, and narrative pressure in sync. The world ticks forward autonomously, aging and evolving even when no one is watching. A director nudges things forward when the world goes quiet, so the simulation never stalls."
          }
        },
        {
          "@type": "Question",
          "name": "What can I do in Aliveville?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pick a hero, walk the 3D town with WASD controls, and observe autonomous villagers going about their daily lives. You can watch social dynamics like grudges and gossip unfold in real time, and click to talk with the AI agents as you explore."
          }
        },
        {
          "@type": "Question",
          "name": "Is Aliveville an AI experiment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Aliveville is a persistent ecosystem exploring autonomous agent behavior, narrative emergence, and playable 3D exploration. It is an interactive AI world experiment where five agents live, remember, and react on their own, building emergent stories you can witness firsthand."
          }
        }
      ]
    })} />
