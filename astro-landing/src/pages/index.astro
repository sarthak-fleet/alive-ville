---
import ThreeBackground from '../components/ThreeBackground.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="bg-[#050507] scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ashbend | Interactive AI World</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;700;900&family=Montserrat:wght@200;300;400;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #f8d44e;
            --accent-muted: #c2a36b;
            --bg: #050507;
        }

        body {
            background-color: var(--bg);
            color: white;
            cursor: none;
            overflow-x: hidden;
        }

        .font-cinzel-dec { font-family: 'Cinzel Decorative', serif; }
        .font-cinzel { font-family: 'Cinzel', serif; }
        .font-montserrat { font-family: 'Montserrat', sans-serif; }
        .font-garamond { font-family: 'Cormorant Garamond', serif; }

        #custom-cursor {
            position: fixed;
            top: 0;
            left: 0;
            width: 40px;
            height: 40px;
            border: 1px solid rgba(248, 212, 78, 0.3);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transition: width 0.3s, height 0.3s, background-color 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            mix-blend-mode: screen;
        }

        #custom-cursor .dot {
            width: 4px;
            height: 4px;
            background-color: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 15px var(--accent);
        }

        .cursor-hover {
            width: 80px !important;
            height: 80px !important;
            background-color: rgba(248, 212, 78, 0.1);
            border-color: rgba(248, 212, 78, 0.6) !important;
        }

        .noise-overlay {
            position: fixed;
            inset: 0;
            z-index: 999;
            pointer-events: none;
            opacity: 0.05;
            background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');
        }

        .parallax-section {
            perspective: 1000px;
        }

        .reveal-up {
            opacity: 0;
            transform: translateY(30px);
            transition: all 1.2s cubic-bezier(0.2, 1, 0.3, 1);
        }

        .reveal-up.active {
            opacity: 1;
            transform: translateY(0);
        }

        .glass-panel {
            background: rgba(10, 12, 16, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(248, 212, 78, 0.15);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .gold-glow {
            text-shadow: 0 0 20px rgba(248, 212, 78, 0.4);
        }

        .btn-cinematic {
            position: relative;
            padding: 18px 48px;
            background: transparent;
            color: white;
            font-weight: 800;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            border: 1px solid rgba(248, 212, 78, 0.5);
            overflow: hidden;
            transition: all 0.4s;
        }

        .btn-cinematic::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(248, 212, 78, 0.2), transparent);
            transition: left 0.6s;
        }

        .btn-cinematic:hover {
            border-color: var(--accent);
            box-shadow: 0 0 30px rgba(248, 212, 78, 0.3);
            transform: translateY(-2px);
        }

        .btn-cinematic:hover::before {
            left: 100%;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .animate-float {
            animation: float 6s ease-in-out infinite;
        }

        .vignette-overlay {
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: radial-gradient(circle at center, transparent 0%, rgba(5, 5, 7, 0.4) 60%, rgba(5, 5, 7, 0.9) 100%);
            z-index: 1;
        }

        @keyframes ticker {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        .animate-ticker {
            animation: ticker 40s linear infinite;
        }
    </style>
</head>
<body class="antialiased">

    <div id="custom-cursor">
        <div class="dot"></div>
    </div>

    <div class="noise-overlay"></div>
    <ThreeBackground />

    <!-- HERO SECTION -->
    <section class="relative w-full h-screen flex flex-col items-center justify-center overflow-hidden parallax-section">
        <div class="absolute inset-0 z-0">
            <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-50 scale-105 transform-gpu" id="hero-video">
                <source src="/assets/villain_lantern_shadow.mp4" type="video/mp4" />
            </video>
            <div class="vignette-overlay"></div>
            <div class="absolute bottom-0 left-0 w-full h-64 bg-gradient-to-t from-[#050507] to-transparent"></div>
        </div>

        <div class="relative z-10 px-6 text-center max-w-6xl">
            <div class="reveal-up active">
                <p class="font-montserrat text-[#c2a36b] tracking-[0.5em] uppercase text-xs sm:text-sm mb-6 gold-glow">The First Interactive AI Fandom RPG</p>
                <h1 class="font-cinzel-dec text-6xl sm:text-8xl md:text-9xl lg:text-[11rem] font-black leading-[0.8] mb-8 tracking-tighter mix-blend-difference">
                    ASHBEND
                </h1>
                <p class="font-garamond italic text-xl sm:text-2xl md:text-4xl text-white/70 max-w-3xl mx-auto leading-relaxed mb-12">
                    A playable 3D RPG simulation where memories persist, gossip spreads, and the world truly reacts.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-8">
                    <button class="btn-cinematic group" onclick="document.getElementById('portal-section').scrollIntoView({behavior: 'smooth'})">
                        <span class="relative z-10">Enter World</span>
                    </button>
                    <a href="#lore" class="font-montserrat text-sm uppercase tracking-[0.3em] text-white/50 hover:text-white transition-colors py-4 border-b border-white/0 hover:border-white/20">
                        Explore Lore
                    </a>
                </div>
            </div>
        </div>

        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center opacity-40 animate-float">
            <span class="font-montserrat text-[0.6rem] uppercase tracking-[0.4em] mb-3">Descend</span>
            <div class="w-px h-16 bg-gradient-to-b from-white to-transparent"></div>
        </div>
    </section>

    <!-- STORY SECTIONS -->
    <section class="relative w-full py-32 px-6 bg-[#050507]">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
            <div class="reveal-up">
                <span class="font-montserrat text-[#c2a36b] tracking-[0.4em] uppercase text-xs mb-4 block">Simulation Engine</span>
                <h2 class="font-cinzel text-5xl md:text-7xl font-bold mb-8 leading-tight">
                    Beyond The <br/> <span class="text-[#f8d44e]">Script</span>
                </h2>
                <p class="font-garamond text-2xl text-white/60 mb-12 leading-relaxed">
                    Unlike traditional RPGs with branching dialogue trees, Ashbend's NPCs are powered by a stateful simulation engine. They don't just follow scripts—they live their lives.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="glass-panel p-8 rounded-lg group hover:border-[#f8d44e]/40 transition-all">
                        <h3 class="font-cinzel text-lg text-[#f8d44e] mb-3 uppercase tracking-wider">Local GraphRAG</h3>
                        <p class="font-montserrat text-sm text-white/50 leading-loose">NPCs retrieve only the memories relevant to their current location and emotional state.</p>
                    </div>
                    <div class="glass-panel p-8 rounded-lg group hover:border-[#f8d44e]/40 transition-all">
                        <h3 class="font-cinzel text-lg text-[#f8d44e] mb-3 uppercase tracking-wider">Global Tensions</h3>
                        <p class="font-montserrat text-sm text-white/50 leading-loose">A background Director injects rumors and escalates mystery when the simulation settles too much.</p>
                    </div>
                    <div class="glass-panel p-8 rounded-lg group hover:border-[#f8d44e]/40 transition-all">
                        <h3 class="font-cinzel text-lg text-[#f8d44e] mb-3 uppercase tracking-wider">3D Playability</h3>
                        <p class="font-montserrat text-sm text-white/50 leading-loose">A browser-tested 3D world view anchors travel, target selection, and visible agent movement.</p>
                    </div>
                    <div class="glass-panel p-8 rounded-lg group hover:border-[#f8d44e]/40 transition-all">
                        <h3 class="font-cinzel text-lg text-[#f8d44e] mb-3 uppercase tracking-wider">World Ingest</h3>
                        <p class="font-montserrat text-sm text-white/50 leading-loose">Import structured world source JSON and compile it into locations, quests, items, factions, and playable objectives.</p>
                    </div>
                    <div class="glass-panel p-8 rounded-lg group hover:border-[#f8d44e]/40 transition-all">
                        <h3 class="font-cinzel text-lg text-[#f8d44e] mb-3 uppercase tracking-wider">Long-Running Agents</h3>
                        <p class="font-montserrat text-sm text-white/50 leading-loose">Autonomous loops continue between player actions, checkpointing world ticks and changing the visible scene.</p>
                    </div>
                </div>
            </div>

            <div class="relative reveal-up delay-300">
                <div class="aspect-[4/5] rounded-lg overflow-hidden border border-white/10 shadow-2xl">
                    <img src="/assets/forge_rekindled.jpg" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000 scale-110 hover:scale-100" alt="The Forge" />
                </div>
                <div class="absolute -bottom-8 -left-8 glass-panel p-8 max-w-xs rounded-sm">
                    <p class="font-garamond italic text-xl text-white/90">"The forge breathes again... but the tension in the village hasn't cleared."</p>
                    <span class="block mt-4 font-montserrat text-[0.6rem] uppercase tracking-widest text-[#c2a36b]">Arin the Blacksmith</span>
                </div>
            </div>
        </div>
    </section>

    <!-- THE PORTAL SECTION -->
    <section id="portal-section" class="relative w-full h-[400vh] bg-[#050507] z-30">
        <div class="sticky top-0 w-full h-screen overflow-hidden flex items-center justify-center">

            <div id="portal-frame" class="absolute inset-0 w-full h-full transform-gpu flex items-center justify-center overflow-hidden">
                <video autoplay loop muted playsinline class="w-full h-full object-cover filter brightness-50 contrast-125" id="portal-video">
                    <source src="/assets/garden_morning.mp4" type="video/mp4" />
                </video>
                <div class="vignette-overlay"></div>
            </div>

            <div id="portal-content" class="relative z-20 text-center px-6">
                <div class="reveal-up active">
                    <h2 class="font-cinzel-dec text-5xl md:text-8xl lg:text-[10rem] font-black uppercase mb-8 tracking-tighter">
                        DIVE IN
                    </h2>
                    <p class="font-garamond italic text-2xl md:text-4xl text-white/80 max-w-2xl mx-auto mb-12 leading-relaxed">
                        The simulation awaits. Scroll to pierce the veil and inhabit the world.
                    </p>
                    <div class="w-px h-32 bg-gradient-to-b from-[#f8d44e] to-transparent mx-auto"></div>
                </div>
            </div>

            <div id="game-overlay" class="absolute inset-0 z-50 opacity-0 pointer-events-none transition-opacity duration-1000 flex flex-col">
                <div class="absolute inset-0 bg-black/20 pointer-events-none"></div>
                <div class="absolute inset-0 shadow-[inset_0_0_300px_rgba(0,0,0,1)] pointer-events-none"></div>

                <!-- SIMULATION TICKER -->
                <div class="absolute bottom-32 left-0 w-full overflow-hidden bg-black/40 backdrop-blur-sm border-y border-white/5 py-2 z-30">
                    <div class="flex whitespace-nowrap animate-ticker">
                        <span class="font-montserrat text-[0.6rem] uppercase tracking-[0.4em] text-[#f8d44e]/60 px-8">Simulation Active: Mira is tending the garden in the Square</span>
                        <span class="font-montserrat text-[0.6rem] uppercase tracking-[0.4em] text-[#f8d44e]/60 px-8">Simulation Active: Arin is rekindling the forge at the Forge</span>
                        <span class="font-montserrat text-[0.6rem] uppercase tracking-[0.4em] text-[#f8d44e]/60 px-8">Simulation Active: Tovan is patrolling the Wood Gate</span>
                        <span class="font-montserrat text-[0.6rem] uppercase tracking-[0.4em] text-[#f8d44e]/60 px-8">Simulation Active: Tension level is Rising (64%)</span>
                    </div>
                </div>

                <div class="absolute top-12 left-12 z-20">                    <div class="reveal-up active">
                        <span class="font-montserrat text-[#f8d44e] tracking-[0.4em] uppercase text-[0.6rem] mb-2 block">Protocol: Active</span>
                        <h3 class="font-cinzel text-3xl text-white tracking-widest">ASHBEND VILLAGE</h3>
                        <div class="flex items-center gap-4 mt-4">
                            <div class="flex gap-1">
                                <div class="w-1 h-3 bg-[#f8d44e]"></div>
                                <div class="w-1 h-3 bg-[#f8d44e]"></div>
                                <div class="w-1 h-3 bg-[#f8d44e]"></div>
                                <div class="w-1 h-3 bg-white/20"></div>
                            </div>
                            <span class="font-montserrat text-[0.6rem] uppercase tracking-widest text-white/40">Simulation Sync 84%</span>
                        </div>
                    </div>
                </div>

                <div class="flex-1 w-full h-full relative cursor-none">
                    <canvas id="game-surface" class="w-full h-full"></canvas>
                </div>

                <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 text-center">
                    <div class="glass-panel px-8 py-4 rounded-full border-white/5 backdrop-blur-2xl">
                        <p class="font-montserrat text-[0.65rem] uppercase tracking-[0.3em] text-white/60">
                            Use W A S D to explore the 3D world · Interact with <span class="text-[#f8d44e] font-bold">NPCs</span>
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- FOOTER / NEXT STEPS -->
    <footer class="relative w-full py-24 px-6 bg-black border-t border-white/5 z-40">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
            <div>
                <h4 class="font-cinzel text-2xl font-bold mb-4 tracking-wider">ASHBEND</h4>
                <p class="font-montserrat text-sm text-white/40 uppercase tracking-widest">Experimental AI World Simulation</p>
            </div>
            <div class="flex gap-12">
                <a href="#" class="font-montserrat text-xs uppercase tracking-widest text-white/60 hover:text-[#f8d44e] transition-colors">Documentation</a>
                <a href="#" class="font-montserrat text-xs uppercase tracking-widest text-white/60 hover:text-[#f8d44e] transition-colors">GitHub</a>
                <a href="#" class="font-montserrat text-xs uppercase tracking-widest text-white/60 hover:text-[#f8d44e] transition-colors">Discord</a>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- CUSTOM CURSOR ---
            const cursor = document.getElementById('custom-cursor');
            document.addEventListener('mousemove', (e) => {
                if (cursor) {
                    cursor.style.left = e.clientX + 'px';
                    cursor.style.top = e.clientY + 'px';
                    cursor.style.transform = 'translate(-50%, -50%)';
                }
            });

            // Handle hover state for cursor
            const interactiveElements = document.querySelectorAll('button, a, .glass-panel');
            interactiveElements.forEach(el => {
                el.addEventListener('mouseenter', () => cursor?.classList.add('cursor-hover'));
                el.addEventListener('mouseleave', () => cursor?.classList.remove('cursor-hover'));
            });

            // --- REVEAL ANIMATIONS ---
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal-up').forEach(el => revealObserver.observe(el));

            // --- PORTAL ZOOM LOGIC ---
            const portalSection = document.getElementById('portal-section');
            const portalFrame = document.getElementById('portal-frame');
            const portalContent = document.getElementById('portal-content');
            const gameOverlay = document.getElementById('game-overlay');
            let gameStarted = false;

            window.addEventListener('scroll', () => {
                if (!portalSection || !portalFrame || !portalContent || !gameOverlay) return;

                const rect = portalSection.getBoundingClientRect();
                const scrollProgress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));

                // Scale up the video as we scroll
                const scale = 1 + Math.pow(scrollProgress, 4) * 40;
                portalFrame.style.transform = `scale(${scale})`;

                // Fade out content
                portalContent.style.opacity = Math.max(0, 1 - scrollProgress * 6).toString();
                portalContent.style.transform = `translateY(${-scrollProgress * 200}px)`;

                // Transition to game
                if (scrollProgress > 0.95) {
                    gameOverlay.style.opacity = '1';
                    gameOverlay.style.pointerEvents = 'auto';
                    if (!gameStarted) {
                        startMiniGame();
                        gameStarted = true;
                    }
                } else {
                    gameOverlay.style.opacity = '0';
                    gameOverlay.style.pointerEvents = 'none';
                }
            });

            // --- MINI GAME LOGIC ---
            function startMiniGame() {
                const canvas = document.getElementById('game-surface') as HTMLCanvasElement;
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (!ctx) return;

                const resize = () => {
                    canvas.width = window.innerWidth;
                    canvas.height = window.innerHeight;
                };
                window.addEventListener('resize', resize);
                resize();

                const sprites = {
                    player: new Image(),
                    mira: new Image(),
                    arin: new Image()
                };
                sprites.player.src = '/assets/game/saitama.svg';
                sprites.mira.src = '/assets/game/tatsumaki.svg';
                sprites.arin.src = '/assets/game/genos.svg';

                const player = { x: canvas.width/2, y: canvas.height/2, w: 60, h: 80, speed: 6, vx: 0, vy: 0 };
                const npcs = [
                    { x: canvas.width/2 - 200, y: canvas.height/2 - 50, w: 55, h: 75, name: 'Mira', img: sprites.mira, msg: 'The herbs are blooming early this year.', typing: 0 },
                    { x: canvas.width/2 + 250, y: canvas.height/2 + 100, w: 60, h: 80, name: 'Arin', img: sprites.arin, msg: 'Something is coming. I feel it in the steel.', typing: 0 }
                ];

                const keys: any = {};
                window.addEventListener('keydown', e => keys[e.key.toLowerCase()] = true);
                window.addEventListener('keyup', e => keys[e.key.toLowerCase()] = false);

                function loop() {
                    if (!ctx || !canvas) return;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);

                    // --- CINEMATIC FOG & LIGHTING ---
                    const fog = ctx.createRadialGradient(player.x, player.y, 0, player.x, player.y, 500);
                    fog.addColorStop(0, 'rgba(5, 5, 7, 0)');
                    fog.addColorStop(1, 'rgba(5, 5, 7, 0.8)');
                    ctx.fillStyle = fog;
                    ctx.fillRect(0, 0, canvas.width, canvas.height);

                    // Update player
                    if (keys['w']) player.y -= player.speed;
                    if (keys['s']) player.y += player.speed;
                    if (keys['a']) player.x -= player.speed;
                    if (keys['d']) player.x += player.speed;

                    // Draw NPCS
                    npcs.forEach(npc => {
                        const dist = Math.hypot(player.x - npc.x, player.y - npc.y);

                        // Shadow
                        ctx.fillStyle = 'rgba(0,0,0,0.4)';
                        ctx.beginPath();
                        ctx.ellipse(npc.x, npc.y + 35, 22, 10, 0, 0, Math.PI*2);
                        ctx.fill();

                        // Sprite
                        if (npc.img.complete) {
                            ctx.save();
                            ctx.shadowColor = 'rgba(0,0,0,0.6)';
                            ctx.shadowBlur = 25;
                            ctx.drawImage(npc.img, npc.x - npc.w/2, npc.y - npc.h/2, npc.w, npc.h);
                            ctx.restore();
                        }

                        // Label
                        ctx.fillStyle = 'rgba(255,255,255,0.4)';
                        ctx.font = 'bold 9px "Montserrat"';
                        ctx.textAlign = 'center';
                        ctx.fillText(npc.name.toUpperCase(), npc.x, npc.y - npc.h/2 - 15);

                        // Interaction
                        if (dist < 150) {
                            npc.typing = Math.min(npc.msg.length, npc.typing + 0.6);

                            ctx.save();
                            ctx.fillStyle = 'rgba(10,12,16,0.95)';
                            ctx.strokeStyle = 'rgba(248,212,78,0.4)';
                            ctx.lineWidth = 1;
                            const tw = 280;
                            const th = 90;
                            const tx = npc.x - tw/2;
                            const ty = npc.y - 130;

                            // Rounded rect for dialogue
                            ctx.beginPath();
                            ctx.roundRect(tx, ty, tw, th, 4);
                            ctx.fill();
                            ctx.stroke();

                            ctx.fillStyle = '#f8d44e';
                            ctx.font = 'bold 11px "Montserrat"';
                            ctx.textAlign = 'left';
                            ctx.letterSpacing = '2px';
                            ctx.fillText(npc.name.toUpperCase(), tx + 20, ty + 30);

                            ctx.fillStyle = 'rgba(255,255,255,0.9)';
                            ctx.font = 'italic 16px "Cormorant Garamond"';
                            ctx.letterSpacing = '0px';
                            ctx.fillText(npc.msg.substring(0, Math.floor(npc.typing)), tx + 20, ty + 60);
                            ctx.restore();
                        } else {
                            npc.typing = 0;
                        }
                    });

                    // Draw player
                    ctx.fillStyle = 'rgba(0,0,0,0.4)';
                    ctx.beginPath();
                    ctx.ellipse(player.x, player.y + 35, 22, 10, 0, 0, Math.PI*2);
                    ctx.fill();

                    if (sprites.player.complete) {
                        ctx.save();
                        ctx.shadowColor = 'rgba(248,212,78,0.3)';
                        ctx.shadowBlur = 35;
                        ctx.drawImage(sprites.player, player.x - player.w/2, player.y - player.h/2, player.w, player.h);
                        ctx.restore();
                    }

                    requestAnimationFrame(loop);
                }
                loop();
            }
        });
    </script>
</body>
</html>
