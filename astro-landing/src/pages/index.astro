---
import ThreeBackground from '../components/ThreeBackground.astro';
import ThreePortal from '../components/ThreePortal.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="bg-[#020203] scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ashment | Interactive AI World</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #f8d44e;
            --accent-muted: #c2a36b;
            --bg: #020203;
            --surface: #0a0a0c;
            --border: rgba(255, 255, 255, 0.05);
            --font-main: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --font-display: 'Cinzel Decorative', serif;
        }

        body {
            background-color: var(--bg);
            color: #e6e6e6;
            font-family: var(--font-main);
            margin: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- PROFESSIONAL UI ELEMENTS --- */
        .glass-card {
            background: rgba(10, 10, 12, 0.4);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 12px;
            transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
        }

        .glass-card:hover {
            border-color: rgba(248, 212, 78, 0.2);
            background: rgba(15, 15, 18, 0.6);
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: 240px;
            gap: 16px;
        }

        .bento-item {
            position: relative;
            overflow: hidden;
        }

        .col-span-2 { grid-column: span 2; }
        .row-span-2 { grid-row: span 2; }

        .btn-pro {
            padding: 12px 28px;
            background: #fff;
            color: #000;
            font-weight: 600;
            font-size: 0.85rem;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-pro:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(255, 255, 255, 0.15);
        }

        .tag {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            padding: 4px 10px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 100px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* --- NAVIGATION --- */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            padding: 24px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(to bottom, var(--bg), transparent);
        }

        .logo {
            font-family: var(--font-display);
            font-size: 1.4rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            color: #fff;
        }

        .nav-links {
            display: flex;
            gap: 32px;
        }

        .nav-links a {
            font-size: 0.75rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #888;
            text-decoration: none;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #fff;
        }

        /* --- HERO --- */
        .hero-title {
            font-family: var(--font-display);
            font-size: clamp(3rem, 10vw, 9rem);
            line-height: 0.9;
            font-weight: 900;
            letter-spacing: -0.02em;
            text-align: center;
            margin: 0;
        }

        .gradient-text {
            background: linear-gradient(180deg, #fff 30%, rgba(255, 255, 255, 0.3) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* --- ANIMATIONS --- */
        @keyframes reveal {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-reveal {
            animation: reveal 1s cubic-bezier(0.2, 1, 0.3, 1) forwards;
        }

        .noise-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            pointer-events: none;
            opacity: 0.04;
            background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');
        }

        /* --- GAME CONTROL INTERFACE --- */
        .control-center {
            background: #050507;
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .control-header {
            padding: 16px 24px;
            background: #0a0a0c;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #4caf50;
            box-shadow: 0 0 10px #4caf50;
        }

        .ticker-line {
            font-family: var(--font-mono);
            font-size: 0.65rem;
            color: #555;
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body>
    <div class="noise-overlay"></div>
    <ThreeBackground />

    <nav>
        <div class="logo">ASHMENT</div>
        <div class="nav-links">
            <a href="#about">World</a>
            <a href="#features">Protocols</a>
            <a href="#portal">Access</a>
            <a href="https://github.com">Source</a>
        </div>
        <button class="btn-pro" onclick="document.getElementById('portal-section').scrollIntoView({behavior: 'smooth'})">
            Enter Ashment
        </button>
    </nav>

    <!-- HERO -->
    <section class="relative min-h-screen flex flex-col items-center justify-center pt-32 pb-20 px-6">
        <div class="absolute inset-0 z-0 overflow-hidden">
            <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-30 grayscale filter contrast-125">
                <source src="/assets/villain_lantern_shadow.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#020203]/80 to-[#020203]"></div>
        </div>

        <div class="relative z-10 max-w-5xl mx-auto text-center space-y-8">
            <div class="flex justify-center">
                <span class="tag">Active AI Ecosystem v1.0.4</span>
            </div>
            <h1 class="hero-title animate-reveal">
                <span class="gradient-text">ASHMENT</span>
            </h1>
            <p class="max-w-2xl mx-auto text-lg text-white/50 font-light leading-relaxed animate-reveal" style="animation-delay: 0.2s">
                Ashment is a playable 3D RPG simulation where autonomous agents live, remember, and evolve. Beyond scripts. Beyond trees. A singular living world.
            </p>
            <div class="flex justify-center gap-6 pt-8 animate-reveal" style="animation-delay: 0.4s">
                <button class="btn-pro" onclick="document.getElementById('portal-section').scrollIntoView({behavior: 'smooth'})">
                    Enter Ashment
                </button>
                <button class="px-8 py-3 border border-white/10 rounded-lg text-sm font-medium hover:bg-white/5 transition-all">
                    Read Whitepaper
                </button>
            </div>
        </div>

        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 opacity-20 flex flex-col items-center gap-4">
            <div class="w-px h-20 bg-white"></div>
            <span class="text-[0.6rem] uppercase tracking-[0.4em]">Scroll to Access</span>
        </div>
    </section>

    <!-- BENTO FEATURES -->
    <section class="max-w-7xl mx-auto px-6 py-40" id="features">
        <div class="mb-20 space-y-4">
            <span class="text-[#f8d44e] font-mono text-xs uppercase tracking-[0.3em]">Core Protocols</span>
            <h2 class="text-4xl md:text-6xl font-bold tracking-tight">Built for persistent <br/> intelligence.</h2>
        </div>

        <div class="bento-grid">
            <!-- 1. GraphRAG -->
            <div class="glass-card bento-item col-span-2 row-span-2 p-10 flex flex-col justify-end group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 group-hover:opacity-40 transition-opacity" data-type="network"></canvas>
                <div class="relative z-10">
                    <span class="tag mb-6 w-fit">Engine / Intelligence</span>
                    <h3 class="text-3xl font-bold mb-4">Local GraphRAG</h3>
                    <p class="text-white/50 text-sm leading-relaxed max-w-sm">
                        NPCs navigate their world using location-aware memory retrieval. They only recall what is relevant to their current context, state, and social bonds.
                    </p>
                </div>
            </div>

            <!-- 2. Agents -->
            <div class="glass-card bento-item col-span-2 p-10 flex flex-col justify-center group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-10 group-hover:opacity-30 transition-opacity" data-type="cycles"></canvas>
                <div class="relative z-10">
                    <h3 class="text-xl font-bold mb-2">Long-Running Agents</h3>
                    <p class="text-white/40 text-sm">Autonomous loops continue even when you are away. The world ticks forward, aging and evolving.</p>
                </div>
            </div>

            <!-- 3. Tensions -->
            <div class="glass-card bento-item p-8 flex flex-col justify-between group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 group-hover:opacity-40 transition-opacity" data-type="energy"></canvas>
                <div class="relative z-10">
                    <div class="w-10 h-10 rounded-full bg-[#f8d44e]/10 flex items-center justify-center text-[#f8d44e]">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                    </div>
                    <div class="mt-6">
                        <h4 class="font-bold text-sm mb-1">Global Tensions</h4>
                        <p class="text-xs text-white/40">Real-time narrative pressure.</p>
                    </div>
                </div>
            </div>

            <!-- 4. World Ingest -->
            <div class="glass-card bento-item p-8 flex flex-col justify-between group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 group-hover:opacity-40 transition-opacity" data-type="matrix"></canvas>
                <div class="relative z-10">
                    <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-sm mb-1">World Ingest</h4>
                        <p class="text-xs text-white/40">Import structured world source JSON and compile playable lore.</p>
                    </div>
                </div>
            </div>

            <!-- 5. 3D View -->
            <div class="glass-card bento-item col-span-2 p-10 flex items-center gap-8 overflow-hidden group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-30 group-hover:opacity-50 transition-opacity" data-type="sculpture"></canvas>
                <div class="relative z-10 flex-1">
                    <h3 class="text-2xl font-bold mb-4">3D Playability</h3>
                    <p class="text-white/40 text-sm leading-relaxed">
                        Navigate a high-fidelity 3D representation of the simulation, with real-time lighting and atmosphere.
                    </p>
                </div>
                <div class="relative z-10 w-40 h-40 bg-white/5 rounded-2xl border border-white/5 rotate-12 translate-x-10 group-hover:scale-110 transition-transform"></div>
            </div>
        </div>
    </section>

    <!-- THE PORTAL SECTION -->
    <section id="portal-section" class="relative w-full h-[600vh] bg-[#020203] z-30">
        <div class="sticky top-0 w-full h-screen overflow-hidden flex items-center justify-center px-6">
            
            <ThreePortal />

            <!-- PORTAL VIDEO -->
            <div id="portal-frame" class="absolute inset-0 w-full h-full transform-gpu flex items-center justify-center overflow-hidden">
                <video autoplay loop muted playsinline class="w-full h-full object-cover filter brightness-[0.35] contrast-125" id="portal-video">
                    <source src="/assets/garden_morning.mp4" type="video/mp4" />
                </video>
                <div class="absolute inset-0 bg-gradient-to-t from-[#020203] via-transparent to-[#020203]"></div>
            </div>

            <!-- TRANSITION TEXT -->
            <div id="portal-content" class="relative z-20 text-center space-y-6">
                <span class="tag">Interface Detected</span>
                <h2 class="font-display text-5xl md:text-8xl font-black uppercase tracking-tight">
                    ACCESS ASHMENT
                </h2>
                <p class="text-white/40 text-lg max-w-xl mx-auto font-light">
                    The world layer is ready. Continue scrolling to bridge the connection.
                </p>
            </div>

            <!-- CONTROL CENTER INTERFACE -->
            <div id="game-overlay" class="absolute inset-0 z-50 opacity-0 pointer-events-none transition-opacity duration-1000 flex flex-col p-10">
                <div class="control-center w-full h-full">

                    <!-- HEADER -->
                    <div class="control-header">
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-3">
                                <div class="status-dot"></div>
                                <span class="font-mono text-[0.6rem] text-white/80 uppercase tracking-widest">World Online</span>
                            </div>
                            <div class="w-px h-4 bg-white/10"></div>
                            <span class="font-display text-xs text-white tracking-widest">ASHMENT_CORE_v1.0</span>
                        </div>
                        <div class="flex gap-4">
                            <button id="audio-toggle" class="text-[0.6rem] font-mono text-white/40 hover:text-white uppercase tracking-widest transition-colors">Audio: Off</button>
                            <div class="w-px h-4 bg-white/10"></div>
                            <span class="text-[0.6rem] font-mono text-white/40 uppercase tracking-widest">Region: Village_01</span>
                        </div>
                    </div>

                    <div class="flex-1 relative flex">
                        <!-- LEFT HUD -->
                        <div class="w-80 border-r border-white/5 bg-[#0a0a0c]/40 backdrop-blur-3xl p-8 flex flex-col gap-10">
                            <div class="space-y-4">
                                <h4 class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">Social Graph</h4>
                                <div class="space-y-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-7 h-7 rounded-sm bg-[#ff8a65] flex items-center justify-center font-display text-[0.6rem] text-black">M</div>
                                        <div class="flex-1">
                                            <div class="flex justify-between text-[0.5rem] font-mono uppercase text-white/60 mb-1">
                                                <span>Mira</span>
                                                <span class="text-[#f8d44e]">Trusted</span>
                                            </div>
                                            <div class="h-[1px] w-full bg-white/5 overflow-hidden">
                                                <div class="h-full bg-[#f8d44e] w-3/4"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-3 opacity-40">
                                        <div class="w-7 h-7 rounded-sm bg-blue-500 flex items-center justify-center font-display text-[0.6rem] text-black">A</div>
                                        <div class="flex-1">
                                            <div class="flex justify-between text-[0.5rem] font-mono uppercase text-white/60 mb-1">
                                                <span>Arin</span>
                                                <span>Neutral</span>
                                            </div>
                                            <div class="h-[1px] w-full bg-white/5 overflow-hidden">
                                                <div class="h-full bg-white/20 w-1/2"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-auto space-y-4">
                                <h4 class="font-mono text-[0.6rem] text-white/30 uppercase tracking-[0.2em]">Activity Log</h4>
                                <div class="space-y-3">
                                    <p class="ticker-line">» Tending Garden [84%]</p>
                                    <p class="ticker-line">» Forging Guard Blade</p>
                                    <p class="ticker-line text-[#f8d44e]">» Gossip Node Detected</p>
                                </div>
                            </div>
                        </div>

                        <!-- MAIN GAME -->
                        <div class="flex-1 relative cursor-none bg-black overflow-hidden group">
                            <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 pointer-events-none" data-type="cycles"></canvas>
                            <canvas id="game-surface" class="relative z-10 w-full h-full"></canvas>

                            <!-- SCANLINE -->
                            <div class="absolute inset-0 pointer-events-none opacity-20 z-20" style="background: repeating-linear-gradient(0deg, rgba(0,0,0,0.1) 0px, rgba(0,0,0,0.1) 1px, transparent 1px, transparent 2px);"></div>
                        </div>
                        <!-- CINEMATIC DIALOGUE OVERLAY -->
                        <div id="cinematic-dialogue" class="absolute inset-0 z-40 opacity-0 pointer-events-none transition-all duration-1000 flex flex-col justify-end p-20">
                            <div class="absolute inset-0 bg-black/80 backdrop-blur-xl"></div>
                            <div class="relative z-10 max-w-3xl mx-auto w-full flex flex-col items-center">
                                <div id="dialogue-portrait" class="w-20 h-20 rounded-full border border-white/10 mb-10 overflow-hidden bg-[#050507] shadow-2xl transition-transform duration-1000 scale-75">
                                    <img src="" id="dialogue-img" class="w-full h-full object-cover" />
                                </div>
                                <h5 id="dialogue-name" class="font-display text-[#f8d44e] text-xl uppercase tracking-[0.4em] mb-6">MIRA</h5>
                                <p id="dialogue-text" class="font-garamond italic text-4xl text-white/90 text-center leading-tight mb-12"></p>
                                <button id="close-dialogue" class="text-[0.6rem] font-mono uppercase tracking-[0.3em] text-white/30 hover:text-white transition-colors py-4 px-10 border border-white/5 rounded-full">
                                    Re-sync Terminal
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- FOOTER CONTROLS -->
                    <div class="px-8 py-4 bg-[#0a0a0c] border-t border-white/5 flex justify-between items-center">
                        <p class="font-mono text-[0.6rem] text-white/20 uppercase tracking-widest">
                            Use W A S D to explore the 3D world · Action: <span class="text-white/60">CLICK_NODE</span>
                        </p>
                        <div class="flex items-center gap-6">
                            <span class="font-mono text-[0.6rem] text-white/20 uppercase tracking-widest">Sync-rate: 12ms</span>
                            <div class="w-24 h-1 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full bg-white/20 w-3/4"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- FOOTER -->
    <footer class="relative py-40 border-t border-white/5 bg-[#020203]">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-20">
            <div class="col-span-2 space-y-8">
                <div class="logo">ASHMENT</div>
                <p class="text-white/30 text-sm max-w-sm leading-relaxed">
                    A world built on persistence. A living ecosystem exploring the boundaries of autonomous agent behavior and narrative emergence.
                </p>
            </div>
            <div class="space-y-6">
                <h4 class="text-[0.7rem] uppercase tracking-widest text-white/80 font-bold">Protocols</h4>
                <ul class="space-y-4 text-sm text-white/30">
                    <li><a href="#" class="hover:text-white transition-colors">GraphRAG v1</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Temporal Ticks</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Memory Persistence</a></li>
                </ul>
            </div>
            <div class="space-y-6">
                <h4 class="text-[0.7rem] uppercase tracking-widest text-white/80 font-bold">Resources</h4>
                <ul class="space-y-4 text-sm text-white/30">
                    <li><a href="#" class="hover:text-white transition-colors">Documentation</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Github</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Discord</a></li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-6 mt-40 pt-10 border-t border-white/5 flex justify-between items-center text-[0.6rem] text-white/10 uppercase tracking-widest font-mono">
            <span>© 2026 ASHMENT</span>
            <span>Core Sync Established</span>
        </div>
    </footer>

    <script>
        import * as THREE from 'three';
        document.addEventListener('DOMContentLoaded', () => {
            // --- BENTO THREE.JS LOGIC ---
            const bentoCanvases = document.querySelectorAll('.bento-canvas');
            bentoCanvases.forEach((canvas: any) => {
                const scene = new THREE.Scene();
                const camera = new THREE.PerspectiveCamera(75, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                renderer.setSize(canvas.clientWidth, canvas.clientHeight);
                camera.position.z = 5;

                const type = canvas.dataset.type;
                let mesh: any;

                if (type === 'network') {
                    const geo = new THREE.IcosahedronGeometry(3, 1);
                    const mat = new THREE.MeshBasicMaterial({ color: 0xf8d44e, wireframe: true, transparent: true, opacity: 0.3 });
                    mesh = new THREE.Mesh(geo, mat);
                } else if (type === 'cycles') {
                    const geo = new THREE.TorusGeometry(3, 0.5, 16, 100);
                    const mat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.2 });
                    mesh = new THREE.Mesh(geo, mat);
                } else if (type === 'energy') {
                    const geo = new THREE.SphereGeometry(2, 16, 16);
                    const mat = new THREE.MeshBasicMaterial({ color: 0xf8d44e, wireframe: true, transparent: true, opacity: 0.4 });
                    mesh = new THREE.Mesh(geo, mat);
                } else if (type === 'matrix') {
                    const geo = new THREE.PlaneGeometry(10, 10, 10, 10);
                    const mat = new THREE.MeshBasicMaterial({ color: 0x3b82f6, wireframe: true, transparent: true, opacity: 0.3 });
                    mesh = new THREE.Mesh(geo, mat);
                } else if (type === 'sculpture') {
                    const geo = new THREE.TorusKnotGeometry(2, 0.6, 100, 16);
                    const mat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.2 });
                    mesh = new THREE.Mesh(geo, mat);
                }

                if (mesh) scene.add(mesh);

                function animate() {
                    requestAnimationFrame(animate);
                    if (mesh) {
                        mesh.rotation.x += 0.005;
                        mesh.rotation.y += 0.005;
                    }
                    renderer.render(scene, camera);
                }
                animate();

                window.addEventListener('resize', () => {
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
                    camera.aspect = canvas.clientWidth / canvas.clientHeight;
                    camera.updateProjectionMatrix();
                });
            });

            // --- REVEAL ANIMATIONS ---
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal-up').forEach(el => revealObserver.observe(el));

            // --- PORTAL ZOOM LOGIC ---
            const portalSection = document.getElementById('portal-section');
            const portalFrame = document.getElementById('portal-frame');
            const portalContent = document.getElementById('portal-content');
            const gameOverlay = document.getElementById('game-overlay');
            let gameStarted = false;

            window.addEventListener('scroll', () => {
                if (!portalSection || !portalFrame || !portalContent || !gameOverlay) return;

                const rect = portalSection.getBoundingClientRect();
                const scrollProgress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));
                const footer = document.querySelector('footer');

                // Scale up the video as we scroll
                const scale = 1 + Math.pow(scrollProgress, 5) * 80;
                portalFrame.style.transform = `scale(${scale})`;
                portalFrame.style.filter = `blur(${scrollProgress * 25}px) brightness(${0.35 + scrollProgress * 0.65})`;

                // Fade out content
                portalContent.style.opacity = Math.max(0, 1 - scrollProgress * 10).toString();
                portalContent.style.transform = `translateY(${-scrollProgress * 400}px) scale(${1 - scrollProgress * 0.3})`;

                // Transition to game
                if (scrollProgress > 0.98) {
                    gameOverlay.style.opacity = '1';
                    gameOverlay.style.pointerEvents = 'auto';
                    if (footer) footer.style.display = 'none';
                    if (!gameStarted) {
                        startMiniGame();
                        gameStarted = true;
                    }
                } else {
                    gameOverlay.style.opacity = '0';
                    gameOverlay.style.pointerEvents = 'none';
                    if (footer) footer.style.display = 'grid';
                }
            });

            // --- MINI GAME LOGIC ---
            let audioCtx: AudioContext | null = null;
            let windGain: GainNode | null = null;
            let currentDialogueNpc: any = null;

            function initAudio() {
                if (audioCtx) return;
                audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
                windGain = audioCtx.createGain();
                windGain.gain.value = 0;
                windGain.connect(audioCtx.destination);

                const bufferSize = 2 * audioCtx.sampleRate;
                const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                const output = noiseBuffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) output[i] = Math.random() * 2 - 1;

                const noise = audioCtx.createBufferSource();
                noise.buffer = noiseBuffer;
                noise.loop = true;
                const filter = audioCtx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.value = 500;
                noise.connect(filter);
                filter.connect(windGain);
                noise.start();
                setInterval(() => {
                    if (!windGain || !audioCtx) return;
                    const now = audioCtx.currentTime;
                    windGain.gain.exponentialRampToValueAtTime(0.05 + Math.random() * 0.05, now + 3);
                    windGain.gain.exponentialRampToValueAtTime(0.01, now + 8);
                }, 12000);
            }

            const dialogueOverlay = document.getElementById('cinematic-dialogue');
            const dialogueName = document.getElementById('dialogue-name');
            const dialogueText = document.getElementById('dialogue-text');
            const dialogueImg = document.getElementById('dialogue-img') as HTMLImageElement;
            const dialoguePortrait = document.getElementById('dialogue-portrait');
            const closeDialogueBtn = document.getElementById('close-dialogue');

            function openDialogue(npc: any) {
                if (!dialogueOverlay || !dialogueName || !dialogueText || !dialogueImg || !dialoguePortrait) return;
                currentDialogueNpc = npc;
                dialogueName.textContent = npc.name.toUpperCase();
                dialogueText.textContent = '';
                dialogueImg.src = npc.img.src;
                dialogueOverlay.style.opacity = '1';
                dialogueOverlay.style.pointerEvents = 'auto';
                dialoguePortrait.style.transform = 'scale(1)';
                let i = 0;
                const typeText = () => {
                    if (i < npc.msg.length && currentDialogueNpc === npc) {
                        dialogueText.textContent += npc.msg.charAt(i);
                        i++;
                        setTimeout(typeText, 25);
                    }
                };
                setTimeout(typeText, 600);
            }

            closeDialogueBtn?.addEventListener('click', () => {
                if (!dialogueOverlay || !dialoguePortrait) return;
                dialogueOverlay.style.opacity = '0';
                dialogueOverlay.style.pointerEvents = 'none';
                dialoguePortrait.style.transform = 'scale(0.75)';
                currentDialogueNpc = null;
            });

            document.getElementById('audio-toggle')?.addEventListener('click', (e) => {
                const btn = e.target as HTMLButtonElement;
                if (!audioCtx) {
                    initAudio();
                    btn.textContent = 'Audio: On';
                    btn.style.color = '#fff';
                    windGain!.gain.value = 0.03;
                } else if (audioCtx.state === 'running') {
                    audioCtx.suspend();
                    btn.textContent = 'Audio: Off';
                    btn.style.color = '';
                } else {
                    audioCtx.resume();
                    btn.textContent = 'Audio: On';
                    btn.style.color = '#fff';
                }
            });

            function startMiniGame() {
                const canvas = document.getElementById('game-surface') as HTMLCanvasElement;
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (!ctx) return;

                const resize = () => {
                    canvas.width = canvas.parentElement!.clientWidth;
                    canvas.height = canvas.parentElement!.clientHeight;
                };
                window.addEventListener('resize', resize);
                resize();

                const sprites = { player: new Image(), mira: new Image(), arin: new Image() };
                sprites.player.src = '/assets/game/saitama.svg';
                sprites.mira.src = '/assets/game/tatsumaki.svg';
                sprites.arin.src = '/assets/game/genos.svg';

                const player = { x: canvas.width/2, y: canvas.height/2, w: 60, h: 80, speed: 5 };
                const npcs = [
                    { x: canvas.width/2 - 250, y: canvas.height/2 - 100, w: 55, h: 75, name: 'Mira', img: sprites.mira, msg: 'The herbs of Ashment bloom best under the silver moon. Have you come to harvest?' },
                    { x: canvas.width/2 + 300, y: canvas.height/2 + 120, w: 60, h: 80, name: 'Arin', img: sprites.arin, msg: 'The steel remembers the heat, just as Ashment remembers its past. Do not lose your way.' }
                ];

                const particles: any[] = [];
                for (let i = 0; i < 40; i++) particles.push({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, s: 1 + Math.random() * 2, v: 0.3 + Math.random() * 0.8, a: 0.1 + Math.random() * 0.2 });

                const keys: any = {};
                window.addEventListener('keydown', e => keys[e.key.toLowerCase()] = true);
                window.addEventListener('keyup', e => keys[e.key.toLowerCase()] = false);

                canvas.addEventListener('mousedown', (e) => {
                    if (currentDialogueNpc) return;
                    const rect = canvas.getBoundingClientRect();
                    const mx = e.clientX - rect.left;
                    const my = e.clientY - rect.top;
                    npcs.forEach(npc => { if (Math.hypot(mx - npc.x, my - npc.y) < 70) openDialogue(npc); });
                });

                function loop() {
                    if (!ctx || !canvas) return;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    if (!currentDialogueNpc) {
                        if (keys['w']) player.y -= player.speed;
                        if (keys['s']) player.y += player.speed;
                        if (keys['a']) player.x -= player.speed;
                        if (keys['d']) player.x += player.speed;
                    }
                    const fog = ctx.createRadialGradient(player.x, player.y, 50, player.x, player.y, 600);
                    fog.addColorStop(0, 'rgba(5, 5, 7, 0)');
                    fog.addColorStop(1, 'rgba(5, 5, 7, 0.98)');
                    particles.forEach(p => {
                        p.y += p.v;
                        if (p.y > canvas.height) p.y = -10;
                        ctx.fillStyle = `rgba(248, 212, 78, ${p.a})`;
                        ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI * 2); ctx.fill();
                    });
                    ctx.fillStyle = fog;
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    npcs.forEach(npc => {
                        const isHovered = Math.hypot(player.x - npc.x, player.y - npc.y) < 110;
                        ctx.fillStyle = 'rgba(0,0,0,0.5)';
                        ctx.beginPath(); ctx.ellipse(npc.x, npc.y + 35, 22, 10, 0, 0, Math.PI*2); ctx.fill();
                        if (npc.img.complete) {
                            ctx.save();
                            const scale = isHovered ? 1.05 : 1;
                            ctx.shadowColor = isHovered ? 'rgba(248, 212, 78, 0.3)' : 'rgba(0,0,0,0.7)';
                            ctx.shadowBlur = 30;
                            ctx.drawImage(npc.img, npc.x - (npc.w * scale)/2, npc.y - (npc.h * scale)/2, npc.w * scale, npc.h * scale);
                            ctx.restore();
                        }
                    });
                    ctx.fillStyle = 'rgba(0,0,0,0.5)';
                    ctx.beginPath(); ctx.ellipse(player.x, player.y + 35, 22, 10, 0, 0, Math.PI*2); ctx.fill();
                    if (sprites.player.complete) {
                        ctx.save();
                        ctx.shadowColor = 'rgba(248, 212, 78, 0.2)';
                        ctx.shadowBlur = 40;
                        ctx.drawImage(sprites.player, player.x - player.w/2, player.y - player.h/2, player.w, player.h);
                        ctx.restore();
                    }
                    requestAnimationFrame(loop);
                }
                loop();
            }
        });
    </script>
</body>
</html>
