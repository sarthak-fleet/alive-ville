<body>
    <!-- HERO first in DOM so h1 is the earliest paint target (nav/overlays are fixed). -->
    <section class="relative min-h-screen flex flex-col items-center justify-center pt-32 pb-20 px-6">
        <div class="absolute inset-0 z-0 overflow-hidden">
            <video preload="none" loop muted playsinline class="w-full h-full object-cover opacity-20 grayscale filter contrast-150" data-hero-video aria-label="Atmospheric video of the town of Ashment">
                <source src="/assets/villain_lantern_shadow.mp4" type="video/mp4" />
            </video>
            <p class="sr-only" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">Atmospheric background video showing the town of Ashment with shifting lantern light and shadow.</p>
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#010102]/90 to-[#010102]"></div>
        </div>

        <div class="relative z-10 max-w-6xl mx-auto text-center space-y-12">
            <div class="flex justify-center">
                <span class="tag border-white/20 text-white/60">Browser-playable AI world, no install</span>
            </div>
            <h1 class="hero-title animate-reveal">
                <span class="gradient-text scramble-text" data-value="ASHMENT">ASHMENT</span>
            </h1>
            <p class="max-w-3xl mx-auto text-xl text-white/40 font-light leading-relaxed animate-reveal" style="animation-delay: 0.2s">
                Walk a 3D town where 5 AI agents live their own day. They remember people, hold grudges, and gossip while you explore.
            </p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-8 pt-8 animate-reveal" style="animation-delay: 0.4s">
                <a href="/game/" class="play-cta magnetic-target">▶ Play Now</a>
                <button class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-white/30 hover:text-white transition-all border-b border-white/0 hover:border-white/20 pb-1 magnetic-target" onclick="document.getElementById('features').scrollIntoView({behavior: 'smooth'})">
                    SEE HOW IT WORKS
                </button>
            </div>
        </div>

        <div class="absolute bottom-16 left-1/2 -translate-x-1/2 opacity-20 flex flex-col items-center gap-6">
            <span class="font-mono text-[0.5rem] uppercase tracking-[0.5em] text-white/40">Continuum Scroll</span>
            <div class="w-[1px] h-24 bg-gradient-to-b from-white via-white/50 to-transparent"></div>
        </div>
    </section>

    <div id="custom-cursor"></div>
    <div id="cursor-follower"></div>
    <div class="chromatic-layer"></div>
    <div class="noise-overlay"></div>

    <!-- TELEMETRY -->
    <div class="telemetry telemetry-left">
        <div class="telemetry-scroll">
            <span>0x4A 0x21 0xFF</span>
            <span>SYNC_RATE_12MS</span>
            <span>CORE_LOAD_84%</span>
            <span>NEURAL_NET_ACTIVE</span>
            <span>0x4A 0x21 0xFF</span>
            <span>AGENT_01_MOVE</span>
            <span>AGENT_02_IDLE</span>
            <span>0x4A 0x21 0xFF</span>
        </div>
    </div>
    <div class="telemetry telemetry-right">
        <div class="telemetry-scroll">
            <span>REGION_VILLAGE_01</span>
            <span>LATENCY_STABLE</span>
            <span>UPLINK_ESTABLISHED</span>
            <span>0x12 0x88 0xCC</span>
            <span>TEMPORAL_TICK_144</span>
            <span>WORLD_STATE_OK</span>
            <span>0x12 0x88 0xCC</span>
            <span>PROTOCOL_X_RUN</span>
        </div>
    </div>
    <nav id="main-nav">
        <div class="logo">ASHMENT</div>
        <div class="nav-links">
            <a href="#about" class="glitch-hover">World</a>
            <a href="#features" class="glitch-hover">Protocols</a>
            <a href="#play" class="glitch-hover">Play</a>
        </div>
        <a href="/game/" class="btn-pro magnetic-target">PLAY IN BROWSER</a>
    </nav>

    <ThreeBackground />

    <!-- BENTO FEATURES -->
    <section class="max-w-7xl mx-auto px-6 py-40" id="features">
        <div class="mb-24 space-y-4">
            <span class="text-[#f8d44e] font-mono text-[0.6rem] uppercase tracking-[0.4em]">Core Protocols</span>
            <h2 class="text-5xl md:text-7xl font-black tracking-tight text-white">Built for agents <br/> that remember.</h2>
        </div>

        <div class="bento-grid">
            <div class="glass-card bento-item col-span-2 row-span-2 p-12 flex flex-col justify-end group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 group-hover:opacity-40 transition-opacity" data-type="network"></canvas>
                <div class="relative z-10">
                    <div class="flex gap-2 mb-8">
                        <span class="tag">Engine / Intelligence</span>
                        <span class="tag border-[#f8d44e]/20 text-[#f8d44e]">v2.0 Upgrade</span>
                    </div>
                    <h3 class="text-4xl font-bold mb-6 text-white">Local GraphRAG</h3>
                    <p class="text-white/40 text-sm leading-relaxed max-w-sm font-light">
                        NPCs pull from location-aware memory. They only recall what fits their current context and who they know.
                    </p>
                </div>
            </div>

            <div class="glass-card bento-item col-span-2 p-12 flex flex-col justify-center group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-10 group-hover:opacity-30 transition-opacity" data-type="cycles"></canvas>
                <div class="relative z-10">
                    <div class="flex gap-2 mb-6">
                        <span class="tag border-[#f8d44e]/20 text-[#f8d44e]">New: Persistent Loops</span>
                    </div>
                    <h3 class="text-2xl font-bold mb-3 text-white">Long-Running Agents</h3>
                    <p class="text-white/40 text-sm font-light leading-relaxed">The agents keep going after you close the tab. The world ages on its own.</p>
                </div>
            </div>

            <div class="glass-card bento-item p-10 flex flex-col justify-between group">
                <canvas class="bento-canvas absolute inset-0 z-0 opacity-20 group-hover:opacity-40 transition-opacity" data-type="energy"></canvas>
                <div class="relative z-10">
                    <div class="w-10 h-10 rounded-full bg-[#f8d44e]/10 flex items-center justify-center text-[#f8d44e]">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                        </svg>
                    </div>
                    <div class="mt-8">
                        <h4 class="font-bold text-xs mb-1 uppercase tracking-widest text-white">Global Tensions</h4>
                        <p class="text-[0.65rem] text-white/30 font-mono">Tension that shifts as you play.</p>
                    </div>
                </div>
            </div>

            <div class="glass-card bento-item p-10 flex flex-col justify-between group">
