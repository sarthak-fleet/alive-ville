    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const heroVideo = document.querySelector<HTMLVideoElement>('[data-hero-video]');
            if (heroVideo) {
                const playHero = () => {
                    void heroVideo.play().catch(() => {});
                };
                if ('requestIdleCallback' in window) {
                    requestIdleCallback(playHero, { timeout: 2500 });
                } else {
                    setTimeout(playHero, 1);
                }
            }

            // --- 99.9999% MAGNETIC CURSOR & INTERACTION ---
            const cursor = document.getElementById('custom-cursor');
            const follower = document.getElementById('cursor-follower');
            let cx = 0, cy = 0; // current
            let tx = 0, ty = 0; // target

            document.addEventListener('mousemove', (e) => {
                tx = e.clientX; ty = e.clientY;
                if (cursor) {
                    cursor.style.left = tx + 'px';
                    cursor.style.top = ty + 'px';
                    cursor.style.transform = 'translate(-50%, -50%)';
                }
            });

            function updateFollower() {
                cx += (tx - cx) * 0.15;
                cy += (ty - cy) * 0.15;
                if (follower) {
                    follower.style.left = cx + 'px';
                    follower.style.top = cy + 'px';
                    follower.style.transform = 'translate(-50%, -50%)';
                }
                requestAnimationFrame(updateFollower);
            }
            updateFollower();

            const interactives = document.querySelectorAll('button, a, .glass-card, .nav-links a');
            interactives.forEach(el => {
                el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
                el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));

                if (el.classList.contains('magnetic-target')) {
                    el.addEventListener('mousemove', (e: any) => {
                        const rect = el.getBoundingClientRect();
                        const x = e.clientX - rect.left - rect.width / 2;
                        const y = e.clientY - rect.top - rect.height / 2;
                        (el as HTMLElement).style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
                        follower!.style.transform = `translate(calc(-50% + ${x * 0.5}px), calc(-50% + ${y * 0.5}px))`;
                    });
                    el.addEventListener('mouseleave', () => {
                        (el as HTMLElement).style.transform = '';
                    });
                }
            });

            // --- TEXT SCRAMBLE (defer — hero h1 must paint as ASHMENT first) ---
            const runScramble = () => {
                const scrambleElements = document.querySelectorAll('.scramble-text');
                scrambleElements.forEach((el: any) => {
                    const finalValue = el.dataset.value;
                    const chars = '!<>-_\\/[]{}—=+*^?#________';
                    let iteration = 0;
                    const interval = setInterval(() => {
                        el.innerText = finalValue.split('').map((char: string, index: number) => {
                            if (index < iteration) return finalValue[index];
                            return chars[Math.floor(Math.random() * chars.length)];
                        }).join('');
                        if (iteration >= finalValue.length) clearInterval(interval);
                        iteration += 1 / 3;
                    }, 40);
                });
            };
            if ('requestIdleCallback' in window) {
                requestIdleCallback(runScramble, { timeout: 3000 });
            } else {
                setTimeout(runScramble, 1);
            }

            // --- BENTO THREE.JS LOGIC (below-fold — init when visible) ---
            let threeModule: typeof import('three') | null = null;
            const loadThree = async () => {
                if (!threeModule) threeModule = await import('three');
                return threeModule;
            };
            const initBentoCanvas = async (canvas: any) => {
                if (canvas.dataset.ready === '1') return;
                canvas.dataset.ready = '1';
                const THREE = await loadThree();
                const scene = new THREE.Scene();
                const camera = new THREE.PerspectiveCamera(75, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                renderer.setSize(canvas.clientWidth, canvas.clientHeight);
                camera.position.z = 5;
                const type = canvas.dataset.type;
                let mesh: any;
                if (type === 'network') {
                    mesh = new THREE.Mesh(new THREE.IcosahedronGeometry(3, 1), new THREE.MeshBasicMaterial({ color: 0xf8d44e, wireframe: true, transparent: true, opacity: 0.3 }));
                } else if (type === 'cycles') {
                    mesh = new THREE.Mesh(new THREE.TorusGeometry(3, 0.5, 16, 100), new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.15 }));
                } else if (type === 'energy') {
                    mesh = new THREE.Mesh(new THREE.SphereGeometry(2, 16, 16), new THREE.MeshBasicMaterial({ color: 0xf8d44e, wireframe: true, transparent: true, opacity: 0.3 }));
                } else if (type === 'matrix') {
                    mesh = new THREE.Mesh(new THREE.PlaneGeometry(10, 10, 10, 10), new THREE.MeshBasicMaterial({ color: 0x3b82f6, wireframe: true, transparent: true, opacity: 0.2 }));
                } else if (type === 'sculpture') {
                    mesh = new THREE.Mesh(new THREE.TorusKnotGeometry(2, 0.6, 100, 16), new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.2 }));
                }
                if (mesh) scene.add(mesh);
                function animate() {
                    requestAnimationFrame(animate);
                    if (mesh) { mesh.rotation.x += 0.003; mesh.rotation.y += 0.003; }
                    renderer.render(scene, camera);
                }
                animate();
                window.addEventListener('resize', () => {
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
                    camera.aspect = canvas.clientWidth / canvas.clientHeight;
                    camera.updateProjectionMatrix();
                });
            };

            const bentoCanvases = document.querySelectorAll('.bento-canvas');
            const bentoObserver = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) initBentoCanvas(entry.target);
                });
            }, { rootMargin: '120px' });
            bentoCanvases.forEach((canvas) => bentoObserver.observe(canvas));

            // --- REVEAL ANIMATIONS ---
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal-up').forEach(el => revealObserver.observe(el));

            // --- PORTAL ZOOM LOGIC ---
            const portalSection = document.getElementById('portal-section');
            const portalFrame = document.getElementById('portal-frame');
            const portalContent = document.getElementById('portal-content');
            const gameOverlay = document.getElementById('game-overlay');
            let gameStarted = false;

            window.addEventListener('scroll', () => {
                if (!portalSection || !portalFrame || !portalContent || !gameOverlay) return;
                const rect = portalSection.getBoundingClientRect();
                const scrollProgress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));
                const nav = document.querySelector('nav');

                const scale = 1 + Math.pow(scrollProgress, 4) * 50;
                portalFrame.style.transform = `scale(${scale})`;
                portalFrame.style.filter = `blur(${scrollProgress * 20}px) brightness(${0.35 + scrollProgress * 0.45})`;
                portalContent.style.opacity = Math.max(0, 1 - scrollProgress * 12).toString();
                portalContent.style.transform = `translateY(${-scrollProgress * 400}px)`;

                if (scrollProgress > 0.94) {
                    gameOverlay.style.opacity = '1';
                    gameOverlay.style.pointerEvents = 'auto';
                    gameOverlay.style.visibility = 'visible';
                    if (nav) nav.style.opacity = '0';
                    if (!gameStarted) { startMiniGame(); gameStarted = true; }
                } else {
                    gameOverlay.style.opacity = '0';
                    gameOverlay.style.pointerEvents = 'none';
                    gameOverlay.style.visibility = 'hidden';
                    if (nav) nav.style.opacity = '1';
                }
            });

            // --- MINI GAME LOGIC ---
            let audioCtx: AudioContext | null = null;
            let windGain: GainNode | null = null;
            let currentDialogueNpc: any = null;

            function initAudio() {
                if (audioCtx) return;
                audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
                windGain = audioCtx.createGain();
                windGain.gain.value = 0;
                windGain.connect(audioCtx.destination);
                const bufferSize = 2 * audioCtx.sampleRate;
                const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                const output = noiseBuffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) output[i] = Math.random() * 2 - 1;
                const noise = audioCtx.createBufferSource();
                noise.buffer = noiseBuffer;
                noise.loop = true;
                const filter = audioCtx.createBiquadFilter();
                filter.type = 'lowpass'; filter.frequency.value = 600;
                noise.connect(filter); filter.connect(windGain);
                noise.start();
                setInterval(() => {
                    if (!windGain || !audioCtx) return;
                    const now = audioCtx.currentTime;
                    windGain.gain.exponentialRampToValueAtTime(0.06 + Math.random() * 0.05, now + 3);
                    windGain.gain.exponentialRampToValueAtTime(0.02, now + 7);
                }, 10000);
            }

            const dialogueOverlay = document.getElementById('cinematic-dialogue');
            const dialogueName = document.getElementById('dialogue-name');
            const dialogueText = document.getElementById('dialogue-text');
            const dialogueImg = document.getElementById('dialogue-img') as HTMLImageElement;
            const dialoguePortrait = document.getElementById('dialogue-portrait');
            const closeDialogueBtn = document.getElementById('close-dialogue');

            function openDialogue(npc: any) {
                if (!dialogueOverlay || !dialogueName || !dialogueText || !dialogueImg || !dialoguePortrait) return;
                currentDialogueNpc = npc;
                dialogueName.textContent = npc.name.toUpperCase();
                dialogueText.textContent = '';
                dialogueImg.src = npc.img.src;
                dialogueOverlay.style.opacity = '1';
                dialogueOverlay.style.pointerEvents = 'auto';
                dialoguePortrait.style.transform = 'scale(1)';
                let i = 0;
                const typeText = () => {
                    if (i < npc.msg.length && currentDialogueNpc === npc) {
                        dialogueText.textContent += npc.msg.charAt(i);
                        i++;
                        setTimeout(typeText, 30);
                    }
                };
                setTimeout(typeText, 400);
            }

            closeDialogueBtn?.addEventListener('click', () => {
                if (!dialogueOverlay || !dialoguePortrait) return;
                dialogueOverlay.style.opacity = '0';
                dialogueOverlay.style.pointerEvents = 'none';
                dialoguePortrait.style.transform = 'scale(0.9)';
                currentDialogueNpc = null;
            });

            document.getElementById('audio-toggle')?.addEventListener('click', (e) => {
                const btn = e.target as HTMLButtonElement;
                if (!audioCtx) {
                    initAudio(); btn.textContent = 'MUTE SOUNDSCAPE'; windGain!.gain.value = 0.04;
                } else if (audioCtx.state === 'running') {
                    audioCtx.suspend(); btn.textContent = 'ENABLE SOUNDSCAPE';
                } else {
                    audioCtx.resume(); btn.textContent = 'MUTE SOUNDSCAPE';
                }
            });

            function startMiniGame() {
                const canvas = document.getElementById('game-surface') as HTMLCanvasElement;
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (!ctx) return;
                const resize = () => {
                    canvas.width = canvas.parentElement!.clientWidth;
                    canvas.height = canvas.parentElement!.clientHeight;
                };
                window.addEventListener('resize', resize);
                resize();
                const sprites = { player: new Image(), mira: new Image(), arin: new Image() };
                sprites.player.src = '/assets/game/saitama.svg';
                sprites.mira.src = '/assets/game/tatsumaki.svg';
                sprites.arin.src = '/assets/game/genos.svg';
                const player = { x: canvas.width/2, y: canvas.height/2, w: 64, h: 86, speed: 5.5 };
                const npcs = [
                    { x: canvas.width/2 - 400, y: canvas.height/2 - 120, w: 60, h: 80, name: 'Mira', img: sprites.mira, msg: 'The herbs of Ashment bloom best under the silver moon. Have you come to harvest?' },
                    { x: canvas.width/2 + 450, y: canvas.height/2 + 180, w: 64, h: 86, name: 'Arin', img: sprites.arin, msg: 'The steel remembers the heat, just as Ashment remembers its past. Do not lose your way.' }
                ];
                const particles: any[] = [];
                for (let i = 0; i < 50; i++) particles.push({ x: Math.random() * canvas.width, y: Math.random() * canvas.height, s: 1.5 + Math.random() * 2.5, v: 0.4 + Math.random() * 1.2, a: 0.05 + Math.random() * 0.25, phase: Math.random() * Math.PI * 2 });
                const keys: any = {};
                window.addEventListener('keydown', e => keys[e.key.toLowerCase()] = true);
                window.addEventListener('keyup', e => keys[e.key.toLowerCase()] = false);
                canvas.addEventListener('mousedown', (e) => {
                    if (currentDialogueNpc) return;
                    const rect = canvas.getBoundingClientRect();
                    const mx = e.clientX - rect.left;
                    const my = e.clientY - rect.top;
                    npcs.forEach(npc => { if (Math.hypot(mx - npc.x, my - npc.y) < 80) openDialogue(npc); });
                });
                function loop() {
                    if (!ctx || !canvas) return;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    if (!currentDialogueNpc) {
                        if (keys['w']) player.y -= player.speed;
                        if (keys['s']) player.y += player.speed;
                        if (keys['a']) player.x -= player.speed;
                        if (keys['d']) player.x += player.speed;
                    }
                    const fog = ctx.createRadialGradient(player.x, player.y, 80, player.x, player.y, 850);
                    fog.addColorStop(0, 'rgba(5, 5, 7, 0)');
                    fog.addColorStop(1, 'rgba(5, 5, 7, 0.98)');
                    particles.forEach(p => {
                        p.y += p.v; p.x += Math.sin(p.phase + p.y / 60) * 0.8;
                        if (p.y > canvas.height) p.y = -20;
                        ctx.fillStyle = `rgba(248, 212, 78, ${p.a})`;
                        ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI * 2); ctx.fill();
                    });
                    ctx.fillStyle = fog;
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    npcs.forEach(npc => {
                        const dist = Math.hypot(player.x - npc.x, player.y - npc.y);
                        const isHovered = dist < 120;
                        ctx.fillStyle = 'rgba(0,0,0,0.6)';
                        ctx.beginPath(); ctx.ellipse(npc.x, npc.y + 40, 26, 12, 0, 0, Math.PI*2); ctx.fill();
                        if (npc.img.complete) {
                            ctx.save();
                            const scale = isHovered ? 1.08 : 1;
                            ctx.shadowColor = isHovered ? 'rgba(248, 212, 78, 0.4)' : 'rgba(0,0,0,0.9)';
                            ctx.shadowBlur = isHovered ? 40 : 25;
                            ctx.drawImage(npc.img, npc.x - (npc.w * scale)/2, npc.y - (npc.h * scale)/2, npc.w * scale, npc.h * scale);
                            ctx.restore();
                        }
                        if (isHovered && !currentDialogueNpc) {
                            ctx.fillStyle = '#f8d44e'; ctx.font = 'bold 9px "Cinzel"'; ctx.textAlign = 'center'; ctx.letterSpacing = '4px'; ctx.fillText('INTERACT', npc.x, npc.y - npc.h/2 - 25);
                        } else {
                            ctx.fillStyle = 'rgba(255,255,255,0.15)'; ctx.font = 'bold 8px "Montserrat"'; ctx.textAlign = 'center'; ctx.letterSpacing = '3px'; ctx.fillText(npc.name.toUpperCase(), npc.x, npc.y - npc.h/2 - 20);
                        }
                    });
                    ctx.fillStyle = 'rgba(0,0,0,0.6)';
                    ctx.beginPath(); ctx.ellipse(player.x, player.y + 40, 26, 12, 0, 0, Math.PI*2); ctx.fill();
                    if (sprites.player.complete) {
                        ctx.save(); ctx.shadowColor = 'rgba(248, 212, 78, 0.3)'; ctx.shadowBlur = 50; ctx.drawImage(sprites.player, player.x - player.w/2, player.y - player.h/2, player.w, player.h); ctx.restore();
                    }
                    requestAnimationFrame(loop);
                }
                loop();
            }
        });
    </script>
</body>
</html>
