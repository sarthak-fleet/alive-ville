---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-black">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700;800;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Montserrat:wght@200;300;400&display=swap" rel="stylesheet">
	</head>
	<body class="text-[#dcdde1] antialiased selection:bg-[#c2a36b]/30 selection:text-white">
		
		<slot />

	</body>
</html>

<style is:global>
	body {
		font-family: 'Montserrat', sans-serif;
		background-color: #000;
	}
	
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Cinzel', serif;
	}

	.font-serif-italic {
		font-family: 'Cormorant Garamond', serif;
	}

	/* Hidden scrollbar for pure immersion */
	::-webkit-scrollbar {
		width: 0px;
		background: transparent;
	}

	.thorgal-title {
		text-shadow: 0 4px 20px rgba(0,0,0,0.9), 0 0 40px rgba(0,0,0,0.5);
	}
</style>
