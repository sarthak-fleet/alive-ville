---
---
<div id="three-ambient" class="ambient-bg fixed inset-0 w-full h-full z-0 pointer-events-none mix-blend-screen opacity-50" aria-hidden="true">
    <div class="ambient-glow glow-1"></div>
    <div class="ambient-glow glow-2"></div>
    <div class="ambient-glow glow-3"></div>
    <div class="ambient-particles">
        {Array.from({ length: 60 }).map((_, i) => {
            const left = (Math.random() * 100).toFixed(2);
            const top = (Math.random() * 100).toFixed(2);
            const size = (Math.random() * 2.5 + 0.5).toFixed(1);
            const delay = (Math.random() * 8).toFixed(2);
            const duration = (Math.random() * 6 + 4).toFixed(2);
            const opacity = (Math.random() * 0.4 + 0.1).toFixed(2);
            return (
                <span
                    class="particle"
                    style={`left:${left}%;top:${top}%;width:${size}px;height:${size}px;animation-delay:${delay}s;animation-duration:${duration}s;opacity:${opacity}`}
                />
            );
        })}
    </div>
</div>

<style>
    .ambient-bg {
        background: radial-gradient(ellipse at 50% 30%, rgba(111, 75, 30, 0.12) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 70%, rgba(248, 212, 78, 0.04) 0%, transparent 50%);
        overflow: hidden;
    }

    .ambient-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }

    .glow-1 {
        width: 500px;
        height: 500px;
        background: rgba(111, 75, 30, 0.3);
        top: 10%;
        left: 15%;
        animation: drift-1 20s ease-in-out infinite;
    }

    .glow-2 {
        width: 350px;
        height: 350px;
        background: rgba(248, 212, 78, 0.08);
        bottom: 15%;
        right: 20%;
        animation: drift-2 25s ease-in-out infinite;
    }

    .glow-3 {
        width: 300px;
        height: 300px;
        background: rgba(168, 124, 58, 0.1);
        top: 50%;
        left: 60%;
        animation: drift-3 30s ease-in-out infinite;
    }

    @keyframes drift-1 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(60px, -40px); }
    }

    @keyframes drift-2 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-50px, 30px); }
    }

    @keyframes drift-3 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(30px, 50px); }
    }

    .ambient-particles {
        position: absolute;
        inset: 0;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        background: #f8d44e;
        animation-name: twinkle;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        will-change: opacity, transform;
    }

    @keyframes twinkle {
        0%, 100% {
            opacity: 0.05;
            transform: translateY(0);
        }
        50% {
            opacity: 0.6;
            transform: translateY(-15px);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .ambient-glow,
        .particle {
            animation: none;
        }
    }
</style>
