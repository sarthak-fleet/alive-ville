<div id="three-ambient" class="fixed inset-0 w-full h-full z-0 pointer-events-none mix-blend-screen opacity-50"></div>

<script>
    import * as THREE from 'three';

    function initThreeAmbient() {
    const container = document.getElementById('three-ambient');
    if (!container) return;
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 4000);
        camera.position.z = 800;

        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: "high-performance", preserveDrawingBuffer: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        const atmosphere = new THREE.Mesh(
            new THREE.PlaneGeometry(2600, 1600, 1, 1),
            new THREE.MeshBasicMaterial({
                color: 0x6f4b1e,
                transparent: true,
                opacity: 0.55,
                depthWrite: false
            })
        );
        atmosphere.position.set(0, 0, -900);
        scene.add(atmosphere);

        // --- 1. THE DATA SEA (Custom Shader Particles) ---
        const particleCount = 15000; // High density
        const geo = new THREE.BufferGeometry();
        const pos = new Float32Array(particleCount * 3);
        const randoms = new Float32Array(particleCount);
        const sizes = new Float32Array(particleCount);

        for (let i = 0; i < particleCount; i++) {
            pos[i * 3] = (Math.random() - 0.5) * 3000;
            pos[i * 3 + 1] = (Math.random() - 0.5) * 3000;
            pos[i * 3 + 2] = (Math.random() - 0.5) * 2000 - 500;
            randoms[i] = Math.random();
            sizes[i] = Math.random() * 2.0 + 0.5;
        }

        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        geo.setAttribute('aRandom', new THREE.BufferAttribute(randoms, 1));
        geo.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));

        const vertexShader = `
            attribute float aRandom;
            attribute float aSize;
            varying float vAlpha;
            varying vec3 vColor;
            uniform float uTime;
            uniform float uScroll;
            uniform vec2 uMouse;

            void main() {
                vec3 pos = position;

                // Organic drift
                pos.x += sin(uTime * 0.2 + pos.y * 0.001) * 40.0;
                pos.y += cos(uTime * 0.15 + pos.x * 0.001) * 30.0;

                // Mouse distortion field
                float mouseDist = distance(uMouse, pos.xy * 0.001);
                if (mouseDist < 0.4) {
                    pos.z += (0.4 - mouseDist) * 300.0;
                }

                // Scroll flow
                pos.y += uScroll * 0.8;
                pos.y = mod(pos.y + 1500.0, 3000.0) - 1500.0;

                vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
                gl_Position = projectionMatrix * mvPosition;

                gl_PointSize = aSize * (1000.0 / -mvPosition.z);

                // Complex color/alpha shifting
                vAlpha = 0.1 + 0.5 * sin(uTime * 0.5 + aRandom * 10.0);
                vColor = mix(vec3(0.97, 0.83, 0.31), vec3(1.0, 1.0, 1.0), aRandom * 0.4);
            }
        `;

        const fragmentShader = `
            varying float vAlpha;
            varying vec3 vColor;
            void main() {
                float dist = distance(gl_PointCoord, vec2(0.5));
                if (dist > 0.5) discard;
                gl_FragColor = vec4(vColor, vAlpha * (1.0 - dist * 2.0));
            }
        `;

        const mat = new THREE.ShaderMaterial({
            vertexShader,
            fragmentShader,
            transparent: true,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            uniforms: {
                uTime: { value: 0 },
                uScroll: { value: 0 },
                uMouse: { value: new THREE.Vector2(0, 0) }
            }
        });

        const cloud = new THREE.Points(geo, mat);
        scene.add(cloud);

        // --- 2. FLOATING DATA NODES ---
        const nodeGroup = new THREE.Group();
        scene.add(nodeGroup);
        const nodeGeo = new THREE.IcosahedronGeometry(2, 0);
        const nodeMat = new THREE.MeshBasicMaterial({ color: 0xf8d44e, wireframe: true, transparent: true, opacity: 0.15 });

        for(let i=0; i<30; i++) {
            const mesh = new THREE.Mesh(nodeGeo, nodeMat);
            mesh.position.set((Math.random()-0.5)*1500, (Math.random()-0.5)*1500, (Math.random()-0.5)*1000);
            mesh.scale.setScalar(Math.random()*10+5);
            mesh.userData = { speed: Math.random()*0.005, axis: new THREE.Vector3(Math.random(), Math.random(), Math.random()).normalize() };
            nodeGroup.add(mesh);
        }

        // --- INTERACTION ---
        let mouseX = 0, mouseY = 0;
        let scrollY = 0;

        window.addEventListener('mousemove', (e) => {
            mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
            mouseY = (e.clientY / window.innerHeight - 0.5) * -2;
            mat.uniforms.uMouse.value.set(mouseX, mouseY);
        });

        window.addEventListener('scroll', () => {
            scrollY = window.scrollY;
        });

        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const t = clock.getElapsedTime();

            mat.uniforms.uTime.value = t;
            mat.uniforms.uScroll.value = scrollY;

            // Camera Sway
            camera.position.x += (mouseX * 100 - camera.position.x) * 0.03;
            camera.position.y += (mouseY * 100 - camera.position.y + 100) * 0.03;
            camera.lookAt(0, 0, -500);

            // Animate Nodes
            nodeGroup.children.forEach((n: any) => {
                n.rotateOnAxis(n.userData.axis, n.userData.speed);
                n.position.y += Math.sin(t * 0.5 + n.position.x) * 0.2;
            });

            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    }

    const schedule = (fn: () => void) => {
        if ('requestIdleCallback' in window) {
            requestIdleCallback(fn, { timeout: 4000 });
        } else {
            setTimeout(fn, 1);
        }
    };
    schedule(initThreeAmbient);
</script>
